{
  "Add shebang": {
    "prefix": ["#!", "shebang"],
    "body": "#!/usr/bin/env python3"
  },
  "Create a print eval statement": {
    "prefix": ["p=", "print="],
    "body": "print(f\"{$1=}\")$0"
  },
  "Get script directory": {
    "prefix": ["script_dir"],
    "body": [
      "from pathlib import Path",
      "",
      "SCRIPT_DIR = Path(__file__).parent.resolve()"
    ]
  },
  "Suppress Pylint": {
    "prefix": ["suppress_pylint"],
    "body": "# pylint: disable=$1"
  },
  "Suppress Pyright": {
    "prefix": ["suppress_pyright"],
    "body": "# pyright: ignore[$1]"
  }
}
