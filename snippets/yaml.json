{
  "Add schema": {
    "prefix": ["$s", "schema"],
    "body": "# yaml-language-server: \\$schema=$1"
  },
  "Create a print eval statement": {
    "prefix": ["p=", "print="],
    "body": "print(f\"{$1=}\")$0"
  },
  "Get script directory": {
    "prefix": ["script_dir"],
    "body": [
      "from pathlib import Path",
      "",
      "SCRIPT_DIR = Path(__file__).parent.resolve()"
    ]
  }
}
