{
  "Add bash shebang": {
    "prefix": ["#!"],
    "body": "#!/usr/bin/env bash"
  },
  "Arg parse": {
    "prefix": ["args"],
    "body": [
      "usage() {",
      "  echo \"Usage: $0 [OPTIONS]\"",
      "  echo '  -h, --help         Display this help message'",
      "  exit 1",
      "}",
      "",
      "while [[ \\$# -gt 0 ]]; do",
      "  case \"\\$1\" in",
      "    *)",
      "      echo \"Error: Unknown option \\$1\" >&2",
      "      usage",
      "      ;;",
      "  esac",
      "done"
    ]
  },
  "Arg parse (positional)": {
    "prefix": ["args_pos"],
    "body": [
      "usage() {",
      "  echo \"Usage: $0 [OPTIONS] [POSITIONAL ARGS]\"",
      "  echo '  -h, --help         Display this help message'",
      "  exit 1",
      "}",
      "",
      "while [[ \\$# -gt 0 ]]; do",
      "  case \"\\$1\" in",
      "    -*)",
      "      echo \"Error: Unknown option \\$1\" >&2",
      "      usage",
      "      ;;",
      "    *)",
      "      POSITIONAL_ARGS+=(\"\\$1\")",
      "      shift 1",
      "      ;;",
      "  esac",
      "done"
    ]
  },
  "Common bash flags": {
    "prefix": ["euo"],
    "body": "set -euo pipefail"
  },
  "Get the directory for the current script": {
    "prefix": ["script_dir", "sd"],
    "body": "script_dir=\"\\$(dirname -- \"\\${BASH_SOURCE[0]:-\\$0}\")\" && readonly script_dir"
  },
  "Get the directory for the current script (POSIX compliant)": {
    "prefix": ["script_dir_posix", "sd_posix"],
    "body": "script_dir=$(CDPATH='' cd -- \"\\$(dirname -- \"\\$0\")\" && pwd) && readonly script_dir"
  },
  "Suppress": {
    "prefix": ["suppress", "disable"],
    "body": "# shellcheck disable=$1"
  }
}
