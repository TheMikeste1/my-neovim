{
  "Add bash shebang": {
    "prefix": ["#!"],
    "body": "#!/usr/bin/env bash"
  },
  "Arg parse": {
    "prefix": ["args"],
    "body": [
      "for arg in \"\\$@\"; do",
      "  case \\$arg in",
      "    *)",
      "      echo \"Unknown option: \\${arg}\"",
      "      exit 1",
      "      ;;",
      "  esac",
      "done"
    ]
  },
  "Common bash flags": {
    "prefix": ["euo"],
    "body": "set -euo pipefail"
  },
  "Get the directory for the current script": {
    "prefix": ["script_dir", "sd"],
    "body": "script_dir=\"\\$(dirname -- \"\\${BASH_SOURCE[0]:-\\$0}\")\" && readonly script_dir"
  },
  "Get the directory for the current script (POSIX compliant)": {
    "prefix": ["script_dir_posix", "sd_posix"],
    "body": "script_dir=$(CDPATH='' cd -- \"\\$(dirname -- \"\\$0\")\" && pwd) && readonly script_dir"
  },
  "Suppress": {
    "prefix": ["suppress", "disable"],
    "body": "# shellcheck disable=$1"
  }
}
